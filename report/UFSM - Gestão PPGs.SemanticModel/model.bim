        "lineageTag": "68361baf-98db-4955-8b69-d6584362a50b",
        "measures": [
          {
            "name": "Aluno ativo no intervalo",
            "expression": [
              "",
              "    VAR SelectedYears = VALUES(dCalendario[Ano])  -- Get the selected years from dCalendario",
              "    VAR ano_ingresso = MIN(V_PRPGP_DISCENTES_POS[Ano ingresso])  -- Project start year",
              "    VAR ano_saida = MAX(V_PRPGP_DISCENTES_POS[Ano saída corrigido])  -- Project end year",
              "    VAR YearsInRange = FILTER(SelectedYears, ano_ingresso <= [Ano] && ano_saida >= [Ano])  ",
              "    -- Check overlap",
              "    RETURN IF(COUNTROWS(YearsInRange) > 0, 1, 0)  -- Return 1 if there is any overlap, otherwise 0"
            ],
            "formatString": "0",
            "lineageTag": "7f0eb5e0-b0d0-4c65-8457-8e96fa8fa25e"
          },
          {
            "name": "Discentes Ativos",
            "expression": "DISTINCTCOUNT(V_PRPGP_DISCENTES_FLUXO[ID_CURSO_ALUNO])",
            "formatString": "#,0",
            "lineageTag": "48e2e493-2d9b-4b1d-8edb-6eb551c0bdf3"
          },
          {
            "name": "Formados por ano de formatura",
            "expression": [
              "CALCULATE(",
              "    distinctcount(V_PRPGP_DISCENTES_POS[Matrícula]),",
              "    V_PRPGP_DISCENTES_POS[Forma saída] = \"Formado\"",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "b1c41e6d-28c5-4e68-b977-888b2137fd42"
          },
          {
            "name": "Doutorandos ativos",
            "expression": [
              "CALCULATE(",
              "     DISTINCTCOUNT(V_PRPGP_DISCENTES_FLUXO[ID_CURSO_ALUNO]),",
              "     V_PRPGP_DISCENTES_POS[Modalidade curso] = \"Doutorado\"",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "b9a547bf-13ae-47b0-afe1-131615bc4896"
          },
          {
            "name": "Mestrandos ativos",
            "expression": [
              "CALCULATE(",
              "     DISTINCTCOUNT(V_PRPGP_DISCENTES_FLUXO[ID_CURSO_ALUNO]),",
              "     V_PRPGP_DISCENTES_POS[Modalidade curso] = \"Mestrado\"",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "810caefd-2db3-44ba-bf56-1d6f4d610316"
          },
          {
            "name": "Pós-doutorandos ativos",
            "expression": [
              "CALCULATE(",
              "     DISTINCTCOUNT(V_PRPGP_DISCENTES_FLUXO[ID_CURSO_ALUNO]),",
              "     V_PRPGP_DISCENTES_POS[Modalidade curso] = \"Pós-Doutorado\"",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "b3177b2a-7a45-4bff-b1d7-0a826d50ec78"
          },
          {
            "name": "Tempo médio para formar (anos)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "CALCULATE(",
              "    AVERAGEX(",
              "        V_PRPGP_DISCENTES_POS,",
              "        VAR AnoSaida = V_PRPGP_DISCENTES_POS[Ano saída]",
              "        VAR AnoIngresso =",
              "            CALCULATE(",
              "                MIN(V_PRPGP_DISCENTES_FLUXO[Ano]),",
              "                ALL(V_PRPGP_DISCENTES_FLUXO[Ano]),",
              "                ALL(V_PRPGP_DISCENTES_FLUXO[Data]),",
              "                REMOVEFILTERS(dCalendario)",
              "            )",
              "        RETURN",
              "            IF(",
              "                ISBLANK(AnoSaida) || ISBLANK(AnoIngresso),",
              "                BLANK(),",
              "                AnoSaida - AnoIngresso",
              "            )",
              "    ),",
              "    V_PRPGP_DISCENTES_POS[Forma saída] = \"Formado\"",
              ")"
            ],
            "lineageTag": "8a2a102f-f6fb-4647-a1b1-44293746b4fb"
          },
          {
            "name": "Tempo médio para formar mestres (anos)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "CALCULATE(",
              "    AVERAGEX(",
              "        V_PRPGP_DISCENTES_POS,",
              "        VAR AnoSaida = V_PRPGP_DISCENTES_POS[Ano saída]",
              "        VAR AnoIngresso =",
              "            CALCULATE(",
              "                MIN(V_PRPGP_DISCENTES_FLUXO[Ano]),",
              "                ALL(V_PRPGP_DISCENTES_FLUXO[Ano]),",
              "                ALL(V_PRPGP_DISCENTES_FLUXO[Data]),",
              "                REMOVEFILTERS(dCalendario)",
              "            )",
              "        RETURN",
              "            IF(",
              "                ISBLANK(AnoSaida) || ISBLANK(AnoIngresso),",
              "                BLANK(),",
              "                AnoSaida - AnoIngresso",
              "            )",
              "    ),",
              "    V_PRPGP_DISCENTES_POS[Forma saída] = \"Formado\",",
              "    V_PRPGP_DISCENTES_POS[Modalidade curso] = \"Mestrado\"",
              ")"
            ],
            "lineageTag": "427b8915-ceea-46f7-9200-7124dc49881e"
          },
          {
            "name": "Tempo médio para formar doutores (anos)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "CALCULATE(",
              "    AVERAGEX(",
              "        V_PRPGP_DISCENTES_POS,",
              "        VAR AnoSaida = V_PRPGP_DISCENTES_POS[Ano saída]",
              "        VAR AnoIngresso =",
              "            CALCULATE(",
              "                MIN(V_PRPGP_DISCENTES_FLUXO[Ano]),",
              "                ALL(V_PRPGP_DISCENTES_FLUXO[Ano]),",
              "                ALL(V_PRPGP_DISCENTES_FLUXO[Data]),",
              "                REMOVEFILTERS(dCalendario)",
              "            )",
              "        RETURN",
              "            IF(",
              "                ISBLANK(AnoSaida) || ISBLANK(AnoIngresso),",
              "                BLANK(),",
              "                AnoSaida - AnoIngresso",
              "            )",
              "    ),",
              "    V_PRPGP_DISCENTES_POS[Forma saída] = \"Formado\",",
              "    V_PRPGP_DISCENTES_POS[Modalidade curso] = \"Doutorado\"",
              ")"
            ],
            "lineageTag": "0c7860aa-6983-47af-8f0c-cccf54c667d7"
          },
          {
            "name": "Tempo médio para formar doutores (todos cursos)(anos)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "CALCULATE(",
              "    AVERAGEX(",
              "        V_PRPGP_DISCENTES_POS,",
              "        VAR AnoSaida = V_PRPGP_DISCENTES_POS[Ano saída]",
              "        VAR AnoIngresso =",
              "            CALCULATE(",
              "                MIN(V_PRPGP_DISCENTES_FLUXO[Ano]),",
              "                ALL(V_PRPGP_DISCENTES_FLUXO[Ano]),",
              "                ALL(V_PRPGP_DISCENTES_FLUXO[Data]),",
              "                REMOVEFILTERS(dCalendario)",
              "            )",
              "        RETURN",
              "            IF(",
              "                ISBLANK(AnoSaida) || ISBLANK(AnoIngresso),",
              "                BLANK(),",
              "                AnoSaida - AnoIngresso",
              "            )",
              "    ),",
              "    V_PRPGP_DISCENTES_POS[Forma saída] = \"Formado\",",
              "    V_PRPGP_DISCENTES_POS[Modalidade curso] = \"Doutorado\",",
              "    ALL(V_PRPGP_PROGRAMAS_POS[ID_UNIDADE_SUP])",
              ")"
            ],
            "lineageTag": "9117a2ab-e18a-4d8b-8824-54d0ef3bc970"
          },
          {
            "name": "Quantidade matriculados",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT(V_PRPGP_DISCENTES_POS[Matrícula]),",
              "    ALL(dCalendario)",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "c42b2ac2-42d3-4524-ac65-6d1ca5045feb"
          },
          {
            "name": "Quantidade formados",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT(V_PRPGP_DISCENTES_POS[Matrícula]),",
              "    V_PRPGP_DISCENTES_POS[Forma saída] = \"Formado\",",
              "    ALL(dCalendario)",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "982b9f11-78df-478f-b197-cb625263d7cd"
          },
          {
            "name": "Taxa de Conclusão",
            "expression": [
              "",
              "DIVIDE([Quantidade formados], [Quantidade matriculados])"
            ],
            "formatString": "0%;-0%;0%",
            "lineageTag": "d2f74a02-231c-4b6d-b9c4-0e3b9dc49fde"
          },
          {
            "name": "Brasileiro",
            "expression": [
              "CALCULATE(",
              "    DISTINCTCOUNT(V_PRPGP_DISCENTES_POS[ID_CURSO_ALUNO]),",
              "    V_PRPGP_DISCENTES_POS[País de origem discente] = \"Brasil\"",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "ad6804cf-3d6e-4719-8dcb-89dd5cc4f158"
          }
        ],
        "partitions": [
          {
            "name": "V_PRPGP_DISCENTES_POS",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = DB2.Database(\"bi.proj.ufsm.br\", \"bee\", [HierarchicalNavigation=true, Implementation=\"Microsoft\"]),",
                "    BEE = Source{[Schema=\"BEE\"]}[Data],",
                "    V_PRPGP_DISCENTES_POS1 = BEE{[Name=\"V_PRPGP_DISCENTES_POS\"]}[Data],",
                "    #\"Renamed Columns\" = Table.RenameColumns(V_PRPGP_DISCENTES_POS1,{{\"ANO_EVASAO\", \"Ano saída\"}, {\"ANO_INGRESSO\", \"Ano ingresso\"}, {\"FORMA_EVASAO\", \"Forma saída\"}, {\"MATRICULA\", \"Matrícula\"}, {\"NOME_ALUNO\", \"Nome aluno\"}, {\"NOME_PAIS_PORTUGUES\", \"País de origem\"}}),",
                "    #\"Inserted Date\" = Table.AddColumn(#\"Renamed Columns\", \"Data ingresso\", each Date.From(Text.From([Ano ingresso], \"pt-BR\")), type date),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Inserted Date\",{{\"MODALIDADE_CURSO\", \"Modalidade curso\"}, {\"COD_CURSO\", \"Código curso\"}, {\"GENERO\", \"Gênero\"}",
                "}),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Renamed Columns1\",{\"Data ingresso\"}),",
                "    #\"Added Custom\" = Table.AddColumn(#\"Removed Columns\", \"Ano saída corrigido\", each if [Ano saída] is null then Date.Year(DateTime.LocalNow()) else [Ano saída]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Added Custom\",{{\"Ano saída corrigido\", type number}}),",
                "    #\"Replaced Value\" = Table.ReplaceValue(#\"Changed Type\",\"F\",\"Feminino\",Replacer.ReplaceText,{\"Gênero\"}),",
                "    #\"Replaced Value1\" = Table.ReplaceValue(#\"Replaced Value\",\"M\",\"Masculino\",Replacer.ReplaceText,{\"Gênero\"}),",
                "    #\"Renamed Columns2\" = Table.RenameColumns(#\"Replaced Value1\",{{\"País de origem\", \"País de origem discente\"}}),",
                "    #\"Added Custom1\" = Table.AddColumn(#\"Renamed Columns2\", \"Origem\", each if [NACIONALIDADE_ITEM] = 1 then \"Brasileiro\"",
                "else if [NACIONALIDADE_ITEM] <> null then \"estrangeiro\"",
                "else null)",
                "in",
                "    #\"Added Custom1\""
              ],
              "type": "m"
            }
          }
        ]
      },
