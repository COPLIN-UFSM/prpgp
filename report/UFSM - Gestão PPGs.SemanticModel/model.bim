        "lineageTag": "1160af50-9af5-4aea-aec8-e2ed241d0a86",
        "partitions": [
          {
            "name": "dCalendario",
            "mode": "import",
            "source": {
              "expression": [
                "ADDCOLUMNS(",
                "    CALENDAR(",
                "        min(V_PRPGP_DOCENTES_POS[Data admissão]), ",
                "        (TODAY())",
                "    ),",
                "    \"Ano\", YEAR([Date])",
                ")"
              ],
              "type": "calculated"
            }
          }
        ]
