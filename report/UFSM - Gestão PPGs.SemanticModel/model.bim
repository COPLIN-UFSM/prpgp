        "lineageTag": "d25995bd-961f-45d0-91b9-8aea0f5164e2",
        "measures": [
          {
            "name": "Quantidade docentes permanentes",
            "expression": [
              "CALCULATE(",
              "    DISTINCTCOUNT(V_PRPGP_DOCENTES_POS[CPF]),",
              "    V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[Tipo de Vínculo] = \"Permanente\"",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "33c7c8fb-3c7d-4e6c-b151-b5c2333a5bcc"
          },
          {
            "name": "Tempo médio de permanência",
            "expression": [
              "",
              "AVERAGEX(",
              "    VALUES(V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[ID_PESSOA]),",
              "    VAR AnoMin = ",
              "        CALCULATE(",
              "            MIN(V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[Ano]),",
              "            ALL(V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[Ano]),",
              "            ALL(V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[Data]),",
              "            REMOVEFILTERS(dCalendario)",
              "        )",
              "    VAR AnoMax = ",
              "        CALCULATE(",
              "            MAX(V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[Ano]),",
              "            ALL(V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[Ano]),",
              "            ALL(V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[Data]),",
              "            REMOVEFILTERS(dCalendario)",
              "        )",
              "    RETURN ",
              "        IF(",
              "            ISBLANK(AnoMin) || ISBLANK(AnoMax),",
              "            BLANK(),",
              "            AnoMax - AnoMin + 1",
              "        )",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "5fa3a188-b1b9-45c5-9fe1-13b152d6f268"
          },
          {
            "name": "Anos vinculado ao programa",
            "expression": [
              "",
              "    VAR AnoReferencia = MAX(V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[Ano])",
              "    VAR AnoIngresso = CALCULATE(",
              "            MIN(V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[Ano]),",
              "            ALL(V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[Ano]),",
              "            ALL(V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[Data]),",
              "            REMOVEFILTERS(dCalendario)",
              "        )",
              "    RETURN IF(",
              "            ISBLANK(AnoIngresso) || ISBLANK(AnoReferencia),",
              "            BLANK(),",
              "            AnoReferencia - AnoIngresso",
              "        )"
            ],
            "formatString": "0",
            "lineageTag": "255d6be7-59fd-40df-a78b-42732a60f571"
          },
          {
            "name": "Quantidade docentes colaboradores",
            "expression": [
              "CALCULATE(",
              "    DISTINCTCOUNT(V_PRPGP_DOCENTES_POS[CPF]),",
              "    V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[Tipo de Vínculo] = \"Colaborador\"",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "0fd8570e-2303-471d-9037-04174e32ea6a"
          },
          {
            "name": "Quantidade docentes visitantes",
            "expression": [
              "CALCULATE(",
              "    DISTINCTCOUNT(V_PRPGP_DOCENTES_POS[CPF]),",
              "    V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[Tipo de Vínculo] = \"Visitante\"",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "8442c448-9045-421f-b42e-0c0b6cc3b407"
          },
          {
            "name": "Professores vinculados 5+ anos",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT(V_PRPGP_DOCENTES_POS[CPF]),",
              "    FILTER(",
              "        VALUES(V_PRPGP_DOCENTES_POS[CPF]),",
              "        NOT ISBLANK([Anos vinculado ao programa]) && [Anos vinculado ao programa] >= 5",
              "    )",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "cb0d5d6b-0305-4f63-9f49-42f16c8628db"
          },
          {
            "name": "Professores vinculados <5 anos",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT(V_PRPGP_DOCENTES_POS[CPF]),",
              "    FILTER(",
              "        VALUES(V_PRPGP_DOCENTES_POS[CPF]),",
              "        NOT ISBLANK([Anos vinculado ao programa]) && [Anos vinculado ao programa] < 5",
              "    )",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "73d4b1f8-2e1c-4989-9414-d41a32028d11"
          },
          {
            "name": "Docentes brasileiros",
            "expression": [
              "CALCULATE(",
              "    DISTINCTCOUNT(V_PRPGP_DOCENTES_POS[CPF]),",
              "    V_PRPGP_DOCENTES_POS[País de origem docente] = \"Brasil\"",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "264d1863-3898-4b34-a85a-98b9cf05affb"
          },
          {
            "name": "Docentes estrangeiros",
            "expression": [
              "CALCULATE(",
              "    DISTINCTCOUNT(V_PRPGP_DOCENTES_POS[CPF]),",
              "    V_PRPGP_DOCENTES_POS[País de origem docente] <> \"Brasil\"",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "1b1ea0cc-c18f-4684-8643-83f3e174f489"
          },
          {
            "name": "Média orientandos por orientador",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "    DIVIDE(",
              "        DISTINCTCOUNT(V_PRPGP_DISCENTES_POS[CPF]),",
              "        DISTINCTCOUNT(V_PRPGP_DISCENTES_POS[ID_ORIENTADOR]",
              "    )",
              ")"
            ],
            "lineageTag": "2b0a72c3-3204-425c-a108-782cec5de77b"
          },
          {
            "name": "Média formados por orientador",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "CALCULATE(",
              "    DIVIDE(",
              "        DISTINCTCOUNT(V_PRPGP_DISCENTES_POS[CPF]),",
              "        DISTINCTCOUNT(V_PRPGP_DISCENTES_POS[ID_ORIENTADOR])",
              "    ),",
              "    V_PRPGP_DISCENTES_POS[Forma saída] = \"Formado\"",
              ")"
            ],
            "lineageTag": "815f0426-d455-44ee-b4f1-22edb958e535"
          },
          {
            "name": "Quantidade docentes",
            "expression": "DISTINCTCOUNT(V_PRPGP_CREDENCIAMENTO_DOCENTE_FLUXO[ID_CONTRATO_RH])",
            "formatString": "#,0",
            "lineageTag": "bccd83af-247c-40a2-886b-cfb69f285472"
          }
        ],
        "partitions": [
          {
            "name": "V_PRPGP_DOCENTES_POS",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = DB2.Database(\"bi.proj.ufsm.br\", \"bee\", [HierarchicalNavigation=true, Implementation=\"Microsoft\"]),",
                "    BEE = Source{[Schema=\"BEE\"]}[Data],",
                "    V_PRPGP_DOCENTES_POS1 = BEE{[Name=\"V_PRPGP_DOCENTES_POS\"]}[Data],",
                "    #\"Renamed Columns\" = Table.RenameColumns(V_PRPGP_DOCENTES_POS1,{{\"DT_ADMISSAO_CARGO\", \"Data ingresso\"}, {\"DT_DESLIGAMENTO\", \"Data desligamento\"}, {\"GENERO\", \"Gênero\"}, {\"NOME_FUNCIONARIO\", \"Nome\"},{\"NOME_PAIS_PORTUGUES\", \"País de origem\"}}),",
                "    #\"Inserted Year\" = Table.AddColumn(#\"Renamed Columns\", \"Ano ingresso\", each Date.Year([Data ingresso]), Int64.Type),",
                "    #\"Inserted Year1\" = Table.AddColumn(#\"Inserted Year\", \"Ano desligamento\", each Date.Year([Data desligamento]), Int64.Type),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Inserted Year1\",{{\"Data ingresso\", \"Data admissão\"}, {\"Nome\", \"Nome docente\"}, {\"TITULACAO\", \"Titulação\"}}),",
                "    #\"Capitalized Each Word\" = Table.TransformColumns(#\"Renamed Columns1\",{{\"Nome docente\", Text.Proper, type text}}),",
                "    #\"Renamed Columns2\" = Table.RenameColumns(#\"Capitalized Each Word\",{{\"País de origem\", \"País de origem docente\"}})",
                "in",
                "    #\"Renamed Columns2\""
              ],
              "type": "m"
            }
          }
        ]
      },
