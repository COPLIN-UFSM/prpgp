{
  "name": "PRPGP",
  "textClasses": {
    "label": {
      "color": "#393D3F",
      "fontFace": "'Segoe UI', wf_segoe-ui_normal, helvetica, arial, sans-serif",
      "fontSize": 12
    },
    "callout": {
      "color": "#393D3F",
      "fontFace": "'Segoe UI Bold', wf_segoe-ui_bold, helvetica, arial, sans-serif",
      "fontSize": 25
    },
    "title": {
      "color": "#393D3F",
      "fontFace": "'Segoe UI Semibold', wf_segoe-ui_semibold, helvetica, arial, sans-serif",
      "fontSize": 14
    },
    "header": {
      "fontFace": "Arial",
      "fontSize": 11,
      "color": "#393D3F"
    }
  },
  "dataColors": [
    "#027BCE",
    "#0496FF",
    "#4BB3FD",
    "#00487C",
    "#3E6680",
    "#393D3F",
    "#000000",
    "#FFFFFF"
