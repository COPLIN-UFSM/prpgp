                "color": "#027BCE"
              }
            }
          }
        ],
        "visualHeader": [
          {
            "foreground": {
              "solid": {
                "color": "#027BCE"
              }
            }
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "backgroundColor": {
              "solid": {
                "color": "#C83E4D"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  },
  "foreground": "#000000",
  "foregroundNeutralSecondary": "#909090",
  "backgroundLight": "#FF009D",
  "foregroundNeutralTertiary": "#F7D488",
  "background": "#FFFFFF",
  "bad": "#C83E4D",
  "neutral": "#F4B860",
  "good": "#06BEE1",
